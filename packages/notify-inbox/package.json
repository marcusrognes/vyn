{
	"name": "@vyn/notify-inbox",
	"version": "0.1.0",
	"description": "Vyn in-app notification adapter \u2014 persisted inbox + prebuilt list/count/markRead actions.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./actions": {
			"types": "./dist/actions.d.ts",
			"import": "./dist/actions.js"
		}
	},
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.json || true",
		"prepublishOnly": "npm run build",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@vyn/core": "*"
	},
	"author": "Marcus Rognes",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/marcusrognes/vyn.git",
		"directory": "packages/notify-inbox"
	},
	"homepage": "https://rognes.guru/vyn/",
	"publishConfig": {
		"access": "public"
	}
}